# ---- Joule MVP configuration ----
# Copy to .env and fill in. Every value has a sensible default.

PORT=3000

# Test the full pipeline with NO external calls and NO cost (synthesized answers).
# Set to false once you've added a real API key below.
DRY_RUN=true

# --- Upstream model provider (any OpenAI-compatible endpoint) ---
# OpenAI:      https://api.openai.com/v1
# OpenRouter:  https://openrouter.ai/api/v1
# Together:    https://api.together.xyz/v1
# Groq:        https://api.groq.com/openai/v1
# Local Ollama:http://localhost:11434/v1
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=

# The two models Joule routes between (small = cheap/low-carbon, large = capable)
MODEL_SMALL=gpt-4o-mini
MODEL_LARGE=gpt-4o

# Routing
ROUTING_ENABLED=true
COMPLEXITY_THRESHOLD=1
CACHE_TTL_MS=1800000

# --- Grid carbon intensity (Electricity Maps free tier) ---
# Get a free token: https://www.electricitymaps.com/free-tier
ELECTRICITYMAPS_TOKEN=
GRID_ZONE=AE
FALLBACK_INTENSITY=450

# --- Deployment mode & data residency (regional/compliance posture) ---
DEPLOYMENT_MODE=cloud         # "cloud" | "self_hosted"
DATA_REGION=AE                # where Joule runs / data is handled
PROVIDER_REGION=US            # where the upstream model endpoint lives (dashboard warns if != DATA_REGION)
LOG_PROMPTS=false             # default OFF: never persist prompt/response text (metadata only)
PII_REDACT=false              # redact emails/phones/long digit runs before logging

# --- ROI view ---
SUBSCRIPTION_COST_MONTHLY=0   # monthly subscription for net-of-fees + payback (0 => not shown)

# --- Quality verification (the differentiator): calibrated + conformal ---
# A cheap routing signal is calibrated (isotonic) to P(acceptable) and gated by a
# distribution-free conformal threshold; the LLM judge only LABELS calibration
# samples (off the serving path). Sampled, not exhaustive; the bound is MARGINAL,
# not per-query. In DRY_RUN the whole pipeline runs offline.
VERIFY_ENABLED=true
VERIFICATION_MODE=conformal   # "conformal" (calibrated gate) | "judge" (v1 fallback)
VERIFY_SAMPLE_RATE=0.1        # fraction of small answers sampled to LABEL for calibration
TARGET_RISK_ALPHA=0.05        # conformal bound on P(unacceptable | routed small)
MIN_CALIBRATION_N=50          # below this: refuse to state a guarantee, fall back
CALIBRATION_REFIT_EVERY=200   # refit isotonic every N new labels
JUDGE_MODELS=                 # csv panel of judge models (blank => the large model)
JUDGE_ACCEPT_THRESHOLD=0.6    # judge score >= this (and hard checks pass) => acceptable
JUDGE_AGREEMENT_THRESHOLD=0.67 # panel agreement below this => low-confidence, excluded
DRIFT_K=3                     # |live mean - cal mean| > K*calStd => drift warning + bias large
DRIFT_MIN_N=30               # min live samples before drift can trigger
# v1 safety-mode fallback (used when not yet calibrated)
QUALITY_THRESHOLD=0.8
VERIFY_ROLLING_WINDOW=20
VERIFY_MIN_SAMPLES=3
VERIFY_PROBE_RATE=0.2
# VERIFY_FORCE_SCORE=0.9      # demo/test only: force the judge score (0..1); leave unset in prod
